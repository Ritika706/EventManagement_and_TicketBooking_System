# --- Server Port ---
PORT=5000
# Backend environment variables

# --- Database ---
MONGODB_URI=your_mongodb_connection_string

# --- JWT ---
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# --- Frontend URL (used in password reset email links) ---
# Preferred: FRONTEND_URL
# - For local on the same PC: http://localhost:3000
# - For phone testing on same Wi‑Fi/LAN: http://<YOUR_PC_LAN_IP>:3000
FRONTEND_URL=http://localhost:3000

# Backward-compatible fallback (optional)
APP_URL=http://localhost:3000
APP_NAME=Eventra

# --- SMTP (Password Reset Emails) ---
# For Gmail, you MUST use an App Password (not your normal Gmail password).
# Steps:
# 1) Enable 2-Step Verification on your Google account
# 2) Create an App Password for "Mail"
# 3) Use it as SMTP_PASS

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Eventra <yourgmail@gmail.com>"

# Optional
SUPPORT_EMAIL=yourgmail@gmail.com
NODE_ENV=development


